# Gemini API — primary LLM (chat, quiz generation, translation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic — optional fallback; if both are empty the app runs in mock mode
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# Database (SQLite for dev, PostgreSQL recommended for prod)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/kompas

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# iSpring LMS (mock mode when URL is empty)
ISPRING_BASE_URL=
ISPRING_API_KEY=

# Local file storage
REGULATIONS_DIR=./data/regulations
UPLOADS_DIR=./data/uploads
